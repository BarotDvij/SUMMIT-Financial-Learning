{
  "expo": {
    "name": "SUMMIT",
    "slug": "summit-mobile",
    "scheme": "summit",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fbfaf6"
    },
    "ios": {
      "bundleIdentifier": "ca.summitlearn.app",
      "supportsTablet": true
    },
    "android": {
      "package": "ca.summitlearn.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e7c0d"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": { "typedRoutes": true },
    "extra": {
      "router": { "origin": false },
      "eas": { "projectId": "PLACEHOLDER-replace-after-eas-init" }
    }
  }
}

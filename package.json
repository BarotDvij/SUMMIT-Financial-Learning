{
  "name": "summit-platform",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yml,yaml}\" --ignore-path .gitignore",
    "db:generate": "pnpm --filter @summit/db generate",
    "db:migrate": "pnpm --filter @summit/db migrate",
    "db:seed": "pnpm --filter @summit/db seed",
    "db:studio": "pnpm --filter @summit/db studio",
    "web": "pnpm --filter @summit/web dev",
    "mobile": "pnpm --filter @summit/mobile start",
    "studio": "pnpm --filter @summit/studio dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.7.2"
  }
}
